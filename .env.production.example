# ============================================================================
# AuctionBall — production environment template
#
# Copy to /var/www/auctionball/.env on your production server and fill in.
# This template assumes:
#   - MySQL 8.0 or MariaDB 10.6+ for the DB
#   - Redis for cache, session, queue
#   - Reverb on its own subdomain (ws.auctionball.com) behind nginx
#   - SMTP / SES / Postmark for mail
#   - S3 (or compatible) for file storage
#
# Before going live: php artisan key:generate, then config:cache + route:cache.
# ============================================================================

APP_NAME=AuctionBall
APP_ENV=production
APP_KEY=                            # php artisan key:generate
APP_DEBUG=false                     # MUST stay false — debug=true leaks env vars in error pages
APP_TIMEZONE=Asia/Dhaka
APP_URL=https://auctionball.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning                   # info=verbose, error=too quiet, warning=balanced

# ---------- Database (MySQL / MariaDB) ----------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=auctionball_prod
DB_USERNAME=auctionball_app         # don't use 'root' in prod
DB_PASSWORD=                        # 24+ char random
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
# DB_SOCKET=/var/run/mysqld/mysqld.sock     # uncomment if connecting via unix socket

# ---------- Session / Cache / Queue (Redis-backed) ----------
SESSION_DRIVER=redis
SESSION_LIFETIME=480                # minutes — 8h covers a full auction day
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.auctionball.com     # leading dot = share across subdomains
SESSION_SECURE_COOKIE=true          # HTTPS only
SESSION_SAME_SITE=lax

CACHE_STORE=redis
CACHE_PREFIX=ab_

QUEUE_CONNECTION=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=                     # set on managed Redis or open ports

# ---------- Reverse-proxy + bid throttling ----------
# Trust the X-Forwarded-* headers from your reverse proxy (nginx / Cloudflare /
# load balancer). Without this, real-IP detection (rate limiting, audit log,
# visitor tracking) sees the proxy IP, not the actual client.
TRUSTED_PROXIES=*

# Per-team bid rate limit. Default 60/min is generous for a real human; lower
# to 30 if a captain accidentally spams + button. Server-side enforcement —
# can't be bypassed from the bidding device.
THROTTLE_BIDS_PER_MINUTE=60

# ---------- Broadcasting (Reverb) ----------
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=auctionball_prod
REVERB_APP_KEY=                     # 32-char random
REVERB_APP_SECRET=                  # 32-char random
REVERB_HOST=ws.auctionball.com
REVERB_PORT=443
REVERB_SCHEME=https

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ---------- Mail (use SMTP, SES, Postmark, Resend, or Mailgun) ----------
MAIL_MAILER=smtp
MAIL_HOST=smtp.your-provider.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@auctionball.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---------- File storage (S3 — needed for multi-instance / failover) ----------
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=auctionball-uploads
AWS_URL=                            # CloudFront URL or empty for direct S3
AWS_USE_PATH_STYLE_ENDPOINT=false

# ---------- Billing — bKash (production / live) ----------
BKASH_MODE=live
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_APP_KEY=
BKASH_APP_SECRET=

# ---------- Billing — PayPal ----------
PAYPAL_MODE=live
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=

# ---------- Vite ----------
VITE_APP_NAME="${APP_NAME}"
