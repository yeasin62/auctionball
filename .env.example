# ============================================================================
# AuctionBall — environment template
# Copy to .env and fill in. Production deploys MUST override at least:
#   APP_ENV=production, APP_DEBUG=false, APP_KEY (php artisan key:generate)
#   APP_URL, DB_*, REDIS_*, REVERB_*, MAIL_*, FILESYSTEM_DISK, AWS_*
# ============================================================================

# ---------- App ----------
APP_NAME=AuctionBall
APP_ENV=local                       # production | staging | local
APP_KEY=                            # php artisan key:generate
APP_DEBUG=true                      # MUST be false in production
APP_TIMEZONE=Asia/Dhaka
APP_URL=http://localhost:8000       # full https URL in prod (https://auctionball.com)

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug                     # info | warning | error in prod

# ---------- Database ----------
# Production MUST use MySQL/MariaDB or PostgreSQL. SQLite cannot handle the
# concurrent writes a live auction generates (each bid = 3 writes: bids row +
# auction_states update + broadcast event), and a single tournament with 8
# teams in a contested lot will hit SQLITE_BUSY errors during peak. Multi-
# tenant (many orgs running auctions in parallel) makes it worse.
#
# Use sqlite ONLY for local development convenience. Never for prod.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=auctionball
DB_USERNAME=auctionball
DB_PASSWORD=
DB_CHARSET=utf8mb4                  # required for Bengali / emoji
DB_COLLATION=utf8mb4_unicode_ci

# Local dev fallback (uncomment + comment the mysql block above):
# DB_CONNECTION=sqlite

# ---------- Session ----------
SESSION_DRIVER=database             # use redis in prod for speed
SESSION_LIFETIME=480                # minutes — 8h covers a full auction day
SESSION_ENCRYPT=false               # true in prod (defence in depth)
SESSION_PATH=/
SESSION_DOMAIN=null                 # .auctionball.com to share across subdomains
SESSION_SECURE_COOKIE=null          # true when serving over HTTPS
SESSION_SAME_SITE=lax

# ---------- Broadcasting (Reverb — required for live auction) ----------
BROADCAST_CONNECTION=reverb         # 'log' = no broadcast (dev only)

REVERB_APP_ID=auctionball
REVERB_APP_KEY=local-key            # any random string in dev; rotate in prod
REVERB_APP_SECRET=local-secret      # any random string in dev; rotate in prod
REVERB_HOST=127.0.0.1               # public hostname/IP in prod
REVERB_PORT=8080                    # 443 behind a reverse proxy in prod
REVERB_SCHEME=http                  # https in prod

# Vite-exposed copies (must match the four above; client reads these at build time)
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ---------- Filesystem ----------
FILESYSTEM_DISK=public              # use 's3' in prod for multi-instance / serverless

# ---------- Queue & Cache ----------
QUEUE_CONNECTION=database           # redis | sqs in prod for throughput
CACHE_STORE=database                # redis in prod for ms-level latency
CACHE_PREFIX=

# ---------- Redis (optional but recommended in prod) ----------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---------- Mail ----------
MAIL_MAILER=log                     # smtp | ses | postmark | resend in prod
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null                # tls when using port 587
MAIL_FROM_ADDRESS="hello@auctionball.com"
MAIL_FROM_NAME="${APP_NAME}"
RESEND_KEY=

# ---------- AI content generation ----------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# ---------- AWS S3 (uploads, PDFs, backups when FILESYSTEM_DISK=s3) ----------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=
AWS_URL=                            # https://cdn.example.com (CloudFront) or empty
AWS_USE_PATH_STYLE_ENDPOINT=false

# ---------- Billing — bKash (manual + automated) ----------
BKASH_MODE=sandbox                  # sandbox | live
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_APP_KEY=
BKASH_APP_SECRET=

# ---------- Billing — PayPal ----------
PAYPAL_MODE=sandbox                 # sandbox | live
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_WEBHOOK_ID=

# ---------- Vite ----------
VITE_APP_NAME="${APP_NAME}"
